            <label><text>" FB:"</text></label>
            <number><halpin>"x-pos-fb"</halpin><font>("Helvetica",11)</font><width>9</width><format>"+4.3f"</format></number>
            <label><text>" Err:"</text></label>
            <number><halpin>"x-f-error"</halpin><font>("Helvetica",11,"bold")</font><width>8</width><format>"+3.4f"</format></number>
            <label><text>" mm"</text></label>
        </hbox>
        <hbox>
            <label><text>"Vit:"</text></label>
            <number><halpin>"x-velocity"</halpin><font>("Helvetica",11)</font><width>7</width><format>"+4.1f"</format></number>
            <label><text>" mm/s  Err:"</text></label>
            <number><halpin>"x-vel-error"</halpin><font>("Helvetica",11)</font><width>6</width><format>"+4.2f"</format></number>
            <label><text>"  RPM:"</text></label>
            <number><halpin>"x-motor-rpm"</halpin><font>("Helvetica",11)</font><width>6</width><format>"+5.0f"</format></number>
        </hbox>
        <hbox>
            <led><halpin>"x-fault"</halpin><on_color>"red"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"Flt "</text></label>
            <led><halpin>"x-warning"</halpin><on_color>"yellow"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"Wrn "</text></label>
            <led><halpin>"x-homed"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"Hm "</text></label>
            <led><halpin>"x-limit-min"</halpin><on_color>"red"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"L- "</text></label>
            <led><halpin>"x-limit-max"</halpin><on_color>"red"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"L+ "</text></label>
            <led><halpin>"x-state-op"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>15</size></led><label><text>"OP "</text></label>
            <button><halpin>"x-fault-reset"</halpin><text>"RST"</text></button>
        </hbox>
    </labelframe>

