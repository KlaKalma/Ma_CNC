    <!-- ============================================================ -->
    <!-- BROCHE VFD                                                    -->
    <!-- EL2008 #1 pos.7 → X1-X8  |  EL4002 pos.6 → AVI             -->
    <!-- EL1008 #3 pos.9 ← Y1-Y2                                     -->
    <!-- ============================================================ -->
    <labelframe text="Broche VFD">

        <!-- Vitesse consigne RPM -->
        <hbox>
            <label><text>"Vitesse : "</text></label>
            <number><halpin>"spindle-rpm"</halpin><font>("Helvetica",13,"bold")</font><width>7</width><format>"5.0f"</format></number>
            <label><text>" RPM"</text></label>
        </hbox>
        <bar>
            <halpin>"spindle-rpm-bar"</halpin>
            <min_>0</min_>
            <max_>18000</max_>
            <bgcolor>"grey"</bgcolor>
            <fillcolor>"blue"</fillcolor>
        </bar>

        <!-- Tension AVI réelle (lue depuis EL4002 aout-0-curr-dc) -->
        <hbox>
            <label><text>"AVI réel : "</text></label>
            <number><halpin>"avi-voltage"</halpin><font>("Helvetica",13,"bold")</font><width>5</width><format>"4.2f"</format></number>
            <label><text>" V  / 10V"</text></label>
        </hbox>
        <bar>
            <halpin>"avi-voltage-bar"</halpin>
            <min_>0</min_>
            <max_>10</max_>
            <bgcolor>"grey"</bgcolor>
            <fillcolor>"green"</fillcolor>
        </bar>

        <!-- Frequence calculee (AVI 10V = 1200 Hz) -->
        <hbox>
            <label><text>"Freq.  : "</text></label>
            <number><halpin>"avi-hz"</halpin><font>("Helvetica",13,"bold")</font><width>6</width><format>"4.0f"</format></number>
            <label><text>" Hz / 1200"</text></label>
        </hbox>
        <bar>
            <halpin>"avi-hz-bar"</halpin>
            <min_>0</min_>
            <max_>1200</max_>
            <bgcolor>"grey"</bgcolor>
            <fillcolor>"orange"</fillcolor>
        </bar>

        <!-- EL2008 #1 — Commandes vers VFD (pos.7) -->
        <labelframe text="Cmds → VFD  (EL2008 #1  pos.4)">
            <hbox>
                <vbox>
                    <hbox>
                        <led><halpin>"el2008-x1"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X1 FWD  "</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x2"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X2 REV  "</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x3"</halpin><on_color>"orange"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X3 Stop "</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x4"</halpin><on_color>"cyan"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X4 JogF "</text></label>
                    </hbox>
                </vbox>
                <vbox>
                    <hbox>
                        <led><halpin>"el2008-x5"</halpin><on_color>"yellow"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X5 Reset "</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x6"</halpin><on_color>"red"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X6 ExtFlt"</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x7"</halpin><on_color>"grey"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X7 MultiS"</text></label>
                    </hbox>
                    <hbox>
                        <led><halpin>"el2008-x8"</halpin><on_color>"grey"</on_color><off_color>"grey"</off_color><size>14</size></led>
                        <label><text>" X8 JogR  "</text></label>
                    </hbox>
                </vbox>
            </hbox>
        </labelframe>

        <!-- EL1008 #3 — Retours VFD (pos.12) -->
        <labelframe text="Retours ← VFD  (EL1008 #3  pos.9)">
            <hbox>
                <led><halpin>"el1008-y1"</halpin><on_color>"red"</on_color><off_color>"grey"</off_color><size>18</size></led>
                <label><text>" Y1 Fault  "</text></label>
                <led><halpin>"el1008-y2"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>18</size></led>
                <label><text>" Y2 Run"</text></label>
            </hbox>
        </labelframe>

        <!-- Boutons de contrôle -->
        <hbox>
            <button><halpin>"spindle-stop-btn"</halpin><text>"STOP (X3)"</text></button>
            <button><halpin>"spindle-fault-reset"</halpin><text>"RESET (X5)"</text></button>
        </hbox>

    </labelframe>

</pyvcp>
