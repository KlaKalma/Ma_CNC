<pyvcp>

    <!-- ============================================================ -->
    <!-- ETHERCAT MASTER                                               -->
    <!-- ============================================================ -->
    <labelframe text="EtherCAT — Master">
        <hbox>
            <led><halpin>"master-state-init"</halpin><on_color>"orange"</on_color><off_color>"grey"</off_color><size>13</size></led>
            <label><text>"Init  "</text></label>
            <led><halpin>"master-state-preop"</halpin><on_color>"yellow"</on_color><off_color>"grey"</off_color><size>13</size></led>
            <label><text>"PreOP  "</text></label>
            <led><halpin>"master-state-safeop"</halpin><on_color>"cyan"</on_color><off_color>"grey"</off_color><size>13</size></led>
            <label><text>"SafeOP  "</text></label>
            <led><halpin>"master-state-op"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>13</size></led>
            <label><text>"OP"</text></label>
        </hbox>
    </labelframe>

    <!-- ============================================================ -->
    <!-- SORTIES — 7 indicateurs                                       -->
    <!--   EL2024 #1 (pos.1) : Ch1=FrX  Ch2=FrY  Ch3=FrZ  Ch4=Spare -->
    <!--   + Enable drives X/Y/Z                                       -->
    <!-- ============================================================ -->
    <labelframe text="Sorties — EL2024 #1 (pos.1)">
        <hbox>
            <vbox>
                <hbox>
                    <led><halpin>"el2024-ch1"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Ch1 — Frein X"</text></label>
                </hbox>
                <hbox>
                    <led><halpin>"el2024-ch2"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Ch2 — Frein Y"</text></label>
                </hbox>
                <hbox>
                    <led><halpin>"el2024-ch3"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Ch3 — Frein Z"</text></label>
                </hbox>
                <hbox>
                    <led><halpin>"el2024-ch4"</halpin><on_color>"green"</on_color><off_color>"grey"</off_color><size>16</size></led>
                    <label><text>" Ch4 — Réservé"</text></label>
                </hbox>
            </vbox>
            <vbox>
                <hbox>
                    <led><halpin>"x-enabled"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Enable X"</text></label>
                </hbox>
                <hbox>
                    <led><halpin>"y-enabled"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Enable Y"</text></label>
                </hbox>
                <hbox>
                    <led><halpin>"z-enabled"</halpin><on_color>"green"</on_color><off_color>"red"</off_color><size>16</size></led>
                    <label><text>" Enable Z"</text></label>
                </hbox>
            </vbox>
        </hbox>
    </labelframe>

