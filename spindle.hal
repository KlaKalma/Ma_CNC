########################################################################
# spindle.hal — Contrôle broche VFD via EtherCAT (types natifs)
#
# Topologie vérifiée le 2026-06-17 :
#   EL2008 #1 : slave 4  → lcec.0.4.dout-N   (0-indexé, commandes XN)
#   EL4002    : slave 6  → lcec.0.6.aout-N-*  (float, scale en RPM)
#   EL1008 #1 : slave 7  → lcec.0.7.din-N    (0-indexé, retours YN)
########################################################################

# scale.rpm-x/y/z : calcul RPM moteur (pyvcp_panel.hal les utilise)
loadrt scale names=scale.rpm-x,scale.rpm-y,scale.rpm-z,scale.avi-voltage,scale.avi-hz

addf scale.rpm-x       servo-thread
addf scale.rpm-y       servo-thread
addf scale.rpm-z       servo-thread
addf scale.avi-voltage servo-thread
addf scale.avi-hz      servo-thread

# Tension AVI réelle : EL4002 aout-0-curr-dc (0-1) × 10 = 0-10V
setp scale.avi-voltage.gain 10.0
# Fréquence calculée : aout-0-curr-dc (0-1) × 1200 = 0-1200 Hz (10V = 1200 Hz)
setp scale.avi-hz.gain 1200.0
net avi-curr-dc lcec.0.6.aout-0-curr-dc => scale.avi-voltage.in scale.avi-hz.in

# --- Commandes numériques → VFD (EL2008 #1, slave 4) ---
# ⚠️ NPN/PNP : entrées VFD FC300 = NPN (actives à 0V). L'EL2008 est sourcing/PNP
# (+24V) → n'active PAS ces entrées. Remplacer le module par un EL2088 (ground
# switching/NPN). Aucun changement ici : mêmes pins dout-N, même logique
# (dout ON = actif). Voir CLAUDE.md "NPN vs PNP" + ethercat-conf.xml pos 4.
# Mapping recâblé le 2026-06-21 (dout-N → borne VFD) :
#   dout-0=X1 Forward   dout-1=X2 Reverse   dout-2=X3 Stop
#   dout-3=X4 Jog FWD   dout-4=X5 Reset     dout-5=X6 Ext Fault
#   dout-6=X7 First Multi Speed (NON FONCTIONNELLE — erreur VFD, ne pas piloter)
#   dout-7=X8 Jog Reverse        (NON PRESENTE)
# Pas de borne "Enable" dans ce câblage : Forward/Reverse = commandes run.
net spindle-fwd    spindle.0.forward => lcec.0.4.dout-0   # X1 Forward
net spindle-rev    spindle.0.reverse => lcec.0.4.dout-1   # X2 Reverse
# dout-2 (X3 Stop)    : bouton PyVCP → connecté dans pyvcp_panel.hal
# dout-3 (X4 Jog FWD) : non connecté
# dout-4 (X5 Reset)   : bouton PyVCP → connecté dans pyvcp_panel.hal
# dout-5 (X6 Ext Fault): non connecté (ne pas activer = pas de défaut forcé)
# dout-6 (X7 Multi Speed): NON FONCTIONNELLE → laisser non connecté
# dout-7 (X8 Jog REV)  : NON PRESENTE → laisser non connecté

# --- Référence analogique → VFD AVI (EL4002, slave 6) ---
# EL4002 natif : aout-N-value (float), scale RPM → tension 0-10V
# tmpdc = value / scale → raw = 32767 * tmpdc
# Avec scale=6000 : value=6000 RPM → tmpdc=1.0 → raw=32767 → 10V
# Adapter scale selon RPM max du VFD
setp lcec.0.6.aout-0-scale 18000.0    # CH1 : 18000 RPM = 10V = 1200 Hz max VFD (8 poles, 15 RPM/Hz)
setp lcec.0.6.aout-0-enable 1         # CH1 toujours actif (0V quand vitesse=0)
net spindle-speed-abs spindle.0.speed-out-abs => lcec.0.6.aout-0-value

setp lcec.0.6.aout-1-scale 1.0        # CH2 : référence 100% fixe
setp lcec.0.6.aout-1-enable 1
setp lcec.0.6.aout-1-value 1.0        # CH2 = 1.0 → 10V (référence max)

# --- Retours VFD → LinuxCNC (EL1008 #1, slave 7) ---
# din-N = VFD borne Y(N+1) — 0-indexé : din-0=Y1, din-1=Y2
net vfd-fault  lcec.0.7.din-0              # Y1 Fault  → affiché via pyvcp
net vfd-run    lcec.0.7.din-1 => spindle.0.at-speed  # Y2 Run → at-speed LinuxCNC
