<?xml version="1.0" encoding="utf-8"?>
<masters>
  <master idx="0" appTimePeriod="500000" refClockSyncCycles="5">
    <!-- LC10E Servo Drive - Position 0 -->
    <!-- Configuration based on working example from forum -->
    <slave idx="0" type="generic" vid="00000766" pid="00000402" configPdos="true">
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="0"/>
      
      <!-- RxPDO: Master -> Slave (Commands to drive) -->
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <!-- CIA402 Controlword -->
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="cia-controlword" halType="u32"/>
          <!-- Modes of operation -->
          <pdoEntry idx="6060" subIdx="00" bitLen="8" halPin="opmode" halType="s32"/>
          <!-- Target Position (for CSP mode) -->
          <pdoEntry idx="607A" subIdx="00" bitLen="32" halPin="target-position" halType="s32"/>
          <!-- Target Velocity (for CSV mode) - units: counts/s -->
          <pdoEntry idx="60FF" subIdx="00" bitLen="32" halPin="target-velocity" halType="s32"/>
        </pdo>
      </syncManager>
      
      <!-- TxPDO: Slave -> Master (Feedback from drive) -->
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <!-- CIA402 Statusword -->
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="cia-statusword" halType="u32"/>
          <!-- Modes of operation display -->
          <pdoEntry idx="6061" subIdx="00" bitLen="8" halPin="opmode-display" halType="s32"/>
          <!-- Position actual value -->
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="actual-position" halType="s32"/>
          <!-- Velocity actual value -->
          <pdoEntry idx="606C" subIdx="00" bitLen="32" halPin="actual-velocity" halType="s32"/>
        </pdo>
      </syncManager>
    </slave>
    
    <!-- EL2024 4Ch. Digital Output 24V - Position 2 -->
    <slave idx="2" type="generic" vid="00000002" pid="07E83052" configPdos="true">
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="0"/>
      
      <!-- RxPDO: Master -> Slave (EL2024 native mapping: 4 PDOs x 1 bit) -->
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="7000" subIdx="01" bitLen="1" halPin="output-1" halType="bit"/>
        </pdo>
        <pdo idx="1601">
          <pdoEntry idx="7010" subIdx="01" bitLen="1" halPin="output-2" halType="bit"/>
        </pdo>
        <pdo idx="1602">
          <pdoEntry idx="7020" subIdx="01" bitLen="1" halPin="output-3" halType="bit"/>
        </pdo>
        <pdo idx="1603">
          <pdoEntry idx="7030" subIdx="01" bitLen="1" halPin="output-4" halType="bit"/>
        </pdo>
      </syncManager>
    </slave>
  </master>
</masters>
