<?xml version="1.0" encoding="utf-8"?>
<!--
  Topologie EtherCAT — vérifiée avec 'ethercat slaves' le 2026-06-17
  dcConf (DC sync) : UNIQUEMENT pour les drives LC10E
  Modules EL Beckhoff : types natifs, pas de dcConf, pas de configPdos

  Pos 0  : EK1100  Bus coupler           (pas de config PDO)
  Pos 1  : EL2024 #1  → type="EL2024"   pins : lcec.0.1.dout-0..3
  Pos 2  : EL2024 #2  (à configurer)
  Pos 3  : EL2024 #3  (à configurer)
  Pos 4  : EL2008 #1  → type="EL2008"   pins : lcec.0.4.dout-0..7
  Pos 5  : EL2008 #2  (à configurer)
  Pos 6  : EL4002     → type="EL4002"   pins : lcec.0.6.aout-0/1-{value,enable,scale,...}
  Pos 7  : EL1008 #1  → type="EL1008"   pins : lcec.0.7.din-0..7
  Pos 8  : EL1008 #2  (à configurer)
  Pos 9  : EL1008 #3  (à configurer)
  Pos 10 : LC10E X    CIA402 CSV          Joint 0
  Pos 11 : LC10E Y    CIA402 CSV          Joint 1
  Pos 12 : LC10E Z    CIA402 CSV          Joint 2
-->
<masters>
  <master idx="0" appTimePeriod="1000000" refClockSyncCycles="5">

    <!-- pos.0 : EK1100 Bus Coupler — aucune config PDO requise -->

    <!-- ── EL2024 #1 — pos.1 — Freins XYZ ───────────────────────── -->
    <slave idx="1" type="EL2024"/>

    <!-- pos.2 : EL2024 #2  (à configurer) -->
    <!-- pos.3 : EL2024 #3  (à configurer) -->

    <!-- ── EL2008 #1 — pos.4 — Commandes VFD X1-X8 ──────────────── -->
    <!-- ⚠️ NPN/PNP : le VFD FC300 a des entrées NPN (actives à 0V).      -->
    <!-- L'EL2008 est sourcing/PNP (+24V) → INCOMPATIBLE, n'active pas    -->
    <!-- les entrées. Remplacer par un EL2088 (ground switching/NPN,      -->
    <!-- drop-in, mêmes pins dout-0..7) : passer type="EL2088" ici.       -->
    <!-- Voir CLAUDE.md section "NPN vs PNP". Tant que le module physique -->
    <!-- est un EL2008, garder type="EL2008".                            -->
    <slave idx="4" type="EL2008"/>

    <!-- pos.5 : EL2008 #2  (à configurer) -->

    <!-- ── EL4002 — pos.6 — Consigne vitesse AVI ─────────────────── -->
    <!-- aout-N-value : float [-1..1] × scale → tension sortie ±10V  -->
    <!-- aout-N-scale : défaut 1.0  (value=1.0 → +10V)               -->
    <slave idx="6" type="EL4002"/>

    <!-- ── EL1008 #1 — pos.7 — Retours VFD Y1/Y2 ────────────────── -->
    <slave idx="7" type="EL1008"/>

    <!-- pos.8 : EL1008 #2  (à configurer — sécurités) -->
    <!-- pos.9 : EL1008 #3  (à configurer) -->

    <!-- ── LC10E X — pos.10 — Joint 0 ───────────────────────────── -->
    <slave idx="10" type="generic" vid="00000766" pid="00000402" configPdos="true">
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="0"/>
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="cia-controlword"  halType="u32"/>
          <pdoEntry idx="6060" subIdx="00" bitLen="8"  halPin="opmode"           halType="s32"/>
          <pdoEntry idx="607A" subIdx="00" bitLen="32" halPin="target-position"  halType="s32"/>
          <pdoEntry idx="60FF" subIdx="00" bitLen="32" halPin="target-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="cia-statusword"   halType="u32"/>
          <pdoEntry idx="6061" subIdx="00" bitLen="8"  halPin="opmode-display"   halType="s32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="actual-position"  halType="s32"/>
          <pdoEntry idx="606C" subIdx="00" bitLen="32" halPin="actual-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
    </slave>

    <!-- ── LC10E Y — pos.11 — Joint 1 ───────────────────────────── -->
    <slave idx="11" type="generic" vid="00000766" pid="00000402" configPdos="true">
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="0"/>
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="cia-controlword"  halType="u32"/>
          <pdoEntry idx="6060" subIdx="00" bitLen="8"  halPin="opmode"           halType="s32"/>
          <pdoEntry idx="607A" subIdx="00" bitLen="32" halPin="target-position"  halType="s32"/>
          <pdoEntry idx="60FF" subIdx="00" bitLen="32" halPin="target-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="cia-statusword"   halType="u32"/>
          <pdoEntry idx="6061" subIdx="00" bitLen="8"  halPin="opmode-display"   halType="s32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="actual-position"  halType="s32"/>
          <pdoEntry idx="606C" subIdx="00" bitLen="32" halPin="actual-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
    </slave>

    <!-- ── LC10E Z — pos.12 — Joint 2 ───────────────────────────── -->
    <slave idx="12" type="generic" vid="00000766" pid="00000402" configPdos="true">
      <dcConf assignActivate="300" sync0Cycle="*1" sync0Shift="0"/>
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halPin="cia-controlword"  halType="u32"/>
          <pdoEntry idx="6060" subIdx="00" bitLen="8"  halPin="opmode"           halType="s32"/>
          <pdoEntry idx="607A" subIdx="00" bitLen="32" halPin="target-position"  halType="s32"/>
          <pdoEntry idx="60FF" subIdx="00" bitLen="32" halPin="target-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halPin="cia-statusword"   halType="u32"/>
          <pdoEntry idx="6061" subIdx="00" bitLen="8"  halPin="opmode-display"   halType="s32"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halPin="actual-position"  halType="s32"/>
          <pdoEntry idx="606C" subIdx="00" bitLen="32" halPin="actual-velocity"  halType="s32"/>
        </pdo>
      </syncManager>
    </slave>

  </master>
</masters>
